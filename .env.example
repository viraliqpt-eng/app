PORT=3000
NODE_ENV=development

# mock cria um fluxo completo com um vídeo demonstrativo local.
# runway escolhe Gen 4 Turbo para imagens e Gen 4.5 quando necessário.
# http liga o projeto a outro gateway externo compatível.
VIDEO_PROVIDER=mock

# Necessário quando VIDEO_PROVIDER=runway.
RUNWAY_API_SECRET=
RUNWAY_MODEL=gen4.5

# Necessário apenas quando VIDEO_PROVIDER=http.
VIDEO_API_URL=
VIDEO_API_KEY=

# Limites do MVP.
MAX_IMAGE_MB=3
MAX_GENERATION_MINUTES=20
GENERATION_POLL_MS=2000
