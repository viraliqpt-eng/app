PORT=3000
NODE_ENV=development

# mock cria um fluxo completo com um vídeo demonstrativo local.
# http liga o projeto a um gateway externo compatível.
VIDEO_PROVIDER=mock

# Necessário apenas quando VIDEO_PROVIDER=http.
VIDEO_API_URL=
VIDEO_API_KEY=

# Limites do MVP.
MAX_IMAGE_MB=10
MAX_GENERATION_MINUTES=20
GENERATION_POLL_MS=2000
